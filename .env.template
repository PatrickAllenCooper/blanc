# API Keys and Endpoints for LLM Evaluation
# Copy this file to .env and fill in your credentials.
# DO NOT COMMIT .env TO GIT.

# ---------------------------------------------------------------------------
# OpenAI (GPT-4o)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Anthropic (Claude 3.5 Sonnet)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Google (Gemini 1.5 Pro)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=...

# ---------------------------------------------------------------------------
# Azure OpenAI (GPT-4o via managed endpoint)
# Obtain from Azure portal → Azure OpenAI resource → Keys and Endpoint
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---------------------------------------------------------------------------
# CURC LLM Hoster (vLLM, OpenAI-compatible, open-source models on Alpine)
#
# The CURC LLM Hoster project runs a vLLM server on Alpine's A100 GPU nodes.
# Access is via SSH tunnel (on your local machine) or directly on the cluster.
#
# Step 1: Submit the vLLM launch job on Alpine:
#   sbatch ~/curc-LLM-hoster/scripts/launch_vllm.slurm
#
# Step 2: Create an SSH tunnel (on your local machine):
#   ~/curc-LLM-hoster/scripts/create_tunnel.sh <job_id>
#
# Step 3: Set CURC_VLLM_BASE_URL to the local tunnel endpoint:
#   CURC_VLLM_BASE_URL=http://localhost:8000
#
# Recommended models (single A100 80GB, AWQ quantised, February 2026):
#   Qwen/Qwen2.5-72B-Instruct-AWQ          (top open-source, ~36 GB)
#   hugging-quants/Meta-Llama-3.3-70B-Instruct-AWQ-INT4  (Llama 3.3, ~35 GB)
#   Qwen/Qwen2.5-32B-Instruct-AWQ          (fastest, ~16 GB)
# ---------------------------------------------------------------------------
CURC_VLLM_BASE_URL=http://localhost:8000
CURC_VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ

# ---------------------------------------------------------------------------
# Evaluation defaults
# ---------------------------------------------------------------------------
DEFAULT_TEMPERATURE=0.0
DEFAULT_MAX_TOKENS=512
BATCH_SIZE=10
SAVE_EVERY=50
CACHE_DIR=cache/responses
